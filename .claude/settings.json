{
  {
  "permissions": {
    // Comandos que Claude puede ejecutar SIN pedir permiso cada vez
    "allow": [
      "Bash(npm run test:*)",
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(cat *)",
      "Bash(ls *)"
    ],
    // Comandos que Claude NUNCA puede ejecutar
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(npm publish*)",
      "Read(.env*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/credentials/**)"
    ]
  },

  // No añadir firma "Co-authored-by: Claude" en cada commit
  "includeCoAuthoredBy": false,

  // Variables de entorno disponibles para Claude en este proyecto
  "env": {
    "NODE_ENV": "development"
  }
}
  "enabledPlugins": {
    "expo@claude-plugins-official": true
  }
}
